generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          String
  createdAt     DateTime       @default(now())
  mentor        Mentor?
  notifications Notification[]
  student       Student?
}

model Student {
  id               String            @id @default(uuid())
  userId           String            @unique
  enrollment       String            @unique
  section          String
  semester         String
  branch           String
  year             String
  cgpa             Float             @default(0)
  rank             Int?
  totalStudents    Int?
  performanceIdx   Float?
  codingScore      Int?
  streak           Int               @default(0)
  verificationCode String?           @unique
  academicRecords  AcademicRecord[]
  attendances      Attendance[]
  badges           Badge[]
  codingProfiles   CodingProfile[]
  dailyAttendances DailyAttendance[]
  semesterCGPAs    SemesterCGPA[]
  user             User              @relation(fields: [userId], references: [id])
  skills           StudentSkill[]
}

model Mentor {
  id               String            @id @default(uuid())
  userId           String            @unique
  teacherId        String?           @unique
  department       String
  designation      String
  section          String
  dailyAttendances DailyAttendance[]
  user             User              @relation(fields: [userId], references: [id])
}

model Subject {
  id               String            @id @default(uuid())
  name             String
  code             String            @unique
  semester         String
  academicRecords  AcademicRecord[]
  attendances      Attendance[]
  dailyAttendances DailyAttendance[]
}

model SemesterCGPA {
  id        String  @id @default(uuid())
  studentId String
  semester  String
  cgpa      Float
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, semester])
}

model AcademicRecord {
  id        String  @id @default(uuid())
  studentId String
  subjectId String
  marks     Float
  maxMarks  Float   @default(100)
  grade     String?
  semester  String
  student   Student @relation(fields: [studentId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, semester])
}

model Attendance {
  id        String  @id @default(uuid())
  studentId String
  subjectId String
  attended  Int
  total     Int
  student   Student @relation(fields: [studentId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
}

model DailyAttendance {
  id        String   @id @default(uuid())
  studentId String
  subjectId String
  date      DateTime @default(now())
  status    String
  mentorId  String
  mentor    Mentor   @relation(fields: [mentorId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, date])
}

model CodingProfile {
  id           String   @id @default(uuid())
  studentId    String
  platform     String
  handle       String
  stats        String
  verified     Boolean  @default(false)
  lastSynced   DateTime @default(now())
  activityData Json?
  student      Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, platform])
}

model Badge {
  id          String  @id @default(uuid())
  studentId   String
  label       String
  description String
  icon        String  @default("Award")
  earned      Boolean @default(false)
  student     Student @relation(fields: [studentId], references: [id])
}

model Skill {
  id       String         @id @default(uuid())
  name     String         @unique
  students StudentSkill[]
}

model StudentSkill {
  id        String  @id @default(uuid())
  studentId String
  skillId   String
  skill     Skill   @relation(fields: [skillId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, skillId])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  type        String
  platform    String?
  link        String?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  category  String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
